pipeline {
  agent any

  triggers {
    pollSCM('H/15 * * * *')
  }

  environment {
    CYPRESS_baseUrl = 'http://localhost:3000'
    CYPRESS_CACHE_FOLDER = "${env.HOME}/.cache/Cypress"
    PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Start App') {
      steps {
        sh 'chmod +x scripts/*.sh && bash scripts/ci-start-services.sh'
      }
    }

    stage('Install Cypress') {
      steps {
        dir('cypress-tests') {
          sh 'npm ci || npm install'
          sh 'npx cypress install'
        }
      }
    }

    stage('Cypress Tests') {
      steps {
        dir('cypress-tests') {
          sh 'npm run test:ci'
        }
      }
    }
  }

  post {
    always {
      sh 'bash scripts/ci-stop-services.sh || true'
      dir('cypress-tests') {
        junit allowEmptyResults: true, testResults: 'cypress/results/*.xml'
        archiveArtifacts artifacts: 'cypress/screenshots/**,cypress/results/**', allowEmptyArchive: true
      }
    }
    success {
      echo 'Cypress: all 6 flows passed!'
    }
    failure {
      echo 'Cypress tests failed. Check screenshots in artifacts.'
    }
  }
}
