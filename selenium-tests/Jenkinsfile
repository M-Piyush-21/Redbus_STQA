pipeline {
  agent any

  triggers {
    pollSCM('H/15 * * * *')
  }

  environment {
    BASE_URL = 'http://localhost:3000'
    PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Start App') {
      steps {
        sh 'chmod +x scripts/*.sh && bash scripts/ci-start-services.sh'
      }
    }

    stage('Selenium Tests') {
      steps {
        dir('selenium-tests') {
          sh 'mvn clean test -DbaseUrl=${BASE_URL} -Dheadless=true'
        }
      }
    }
  }

  post {
    always {
      sh 'bash scripts/ci-stop-services.sh || true'
      dir('selenium-tests') {
        junit allowEmptyResults: true, testResults: 'target/surefire-reports/*.xml'
        publishHTML(target: [
          allowMissing: true,
          alwaysLinkToLastBuild: true,
          keepAll: true,
          reportDir: 'target/surefire-reports',
          reportFiles: 'index.html',
          reportName: 'TestNG HTML Report'
        ])
        archiveArtifacts artifacts: 'target/surefire-reports/**', allowEmptyArchive: true
      }
      script {
        try {
          step([$class: 'TestNGTestPublisher', reportFilenamePattern: 'selenium-tests/target/surefire-reports/testng-results.xml'])
        } catch (err) {
          echo "TestNG plugin step skipped: ${err.message}"
        }
      }
    }
    success {
      echo 'Selenium: all 6 flows passed!'
    }
    failure {
      echo 'Selenium tests failed. Check console and surefire-reports.'
    }
  }
}
